# Copy to .vps-control.env (gitignored) and paste the two values Marc gives you.
# With these, ./vpsctl.sh on|off|status controls the Windows VPS — no AWS creds.
# The URL isn't secret on its own (the token gates it); the token is — keep it safe.
SPAWN_VPS_CONTROL_URL=https://<your-lambda-id>.lambda-url.us-east-1.on.aws/
SPAWN_VPS_TOKEN=<the-shared-token-from-marc>
